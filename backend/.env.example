# this file is a template showing every environment variable the backend needs
# copy this to .env and fill in your real values (never commit .env to git)

# neon postgres connection string (get this from your neon dashboard after creating a project)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# gemini api key (get this from google ai studio at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# comma separated list of frontend origins allowed to call this api
# in development this is localhost, in production it will be your vercel url
ALLOWED_ORIGINS=http://localhost:3000
